# Ejemplo de variables de entorno para Coolify
# COPIAR este archivo a la sección "Environment Variables" del resource en Coolify.

# === LLM Providers (al menos uno es requerido) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
NVIDIA_API_KEY=
AISA_API_KEY=

# === Chatwoot ===
CHATWOOT_BASE_URL=https://chat.almanac.lat
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_AGENT_NAME=Nel AI Vendedor
CHATWOOT_AGENT_EMAIL=nel-ai-vendedor@almanac.lat
CHATWOOT_INBOX_IDS=2,4
CHATWOOT_MODE=auto
CHATWOOT_IGNORE_AGENT_MESSAGES=true

# === Daemon ===
HERMES_GATEWAY_URL=http://127.0.0.1:8642
NEL_DAEMON_INTERVAL=8
NEL_WEBHOOK_HOST=127.0.0.1
NEL_WEBHOOK_PORT=8766
