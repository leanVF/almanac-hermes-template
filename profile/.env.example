# Per-profile secrets for nel-ai-vendedor (ALMANAC vendedor WhatsApp Business)
#
# INSTRUCCIONES:
# - Behavioral settings van en config.yaml, NO acá.
# - Llená las variables cuando integres cada servicio.
# - NO commitear este archivo a git (.gitignore lo excluye por defecto).

# ============================================================================
# LLM (ya configurado vía auth.json — OAuth Nous Portal copiada del default)
# ============================================================================
# No requiere variable acá. El perfil usa MiniMax-M3 vía OAuth.
# Para cambiar de modelo: hermes -p nel-ai-vendedor model


# ============================================================================
# WHATSAPP BUSINESS OFICIAL (Meta Cloud API) — configurar cuando llegue el momento
# ============================================================================
# Documentación: https://developers.facebook.com/docs/whatsapp/cloud-api
# Requisitos:
#   1. App en Meta for Developers
#   2. WhatsApp Business Account verificado
#   3. Número de teléfono dedicado (no usar el personal)
#   4. Webhook URL apuntando al gateway de Hermes
#
# WA_PHONE_NUMBER_ID=          # ID del número en Meta (ej: 123456789012345)
# WA_BUSINESS_ACCOUNT_ID=      # ID de la cuenta de WhatsApp Business
# WA_ACCESS_TOKEN=              # System user token (no expira) o app token
# WA_WEBHOOK_VERIFY_TOKEN=      # Token que vos definís para verificar el webhook
# WA_APP_SECRET=                # App secret de Meta para validar firmas
# WA_API_VERSION=v21.0          # Versión de la API (default: v21.0)


# ============================================================================
# TELEGRAM (alertas al grupo de Leandro/Matías)
# Configurado: 2026-07-17 (Nel AI via terminal)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Requisitos:
#   1. Crear bot con @BotFather
#   2. Obtener el token
#   3. Agregar el bot al grupo de ALMANAC
#   4. Obtener el chat_id del grupo (puede ser negativo para grupos)
#
# TG_BOT_TOKEN=                 # Token del bot de alertas (NO el mismo que el bot principal)
# TG_CHAT_ID=                   # chat_id del grupo de ALMANAC (puede ser negativo)


# ============================================================================
# GOOGLE CALENDAR (consultar disponibilidad para agendar reuniones)
# ============================================================================
# Documentación: https://developers.google.com/calendar/api/quickstart/python
# Requisitos:
#   1. Crear proyecto en Google Cloud Console
#   2. Habilitar Calendar API
#   3. Crear OAuth 2.0 credentials (Service Account o Web Application)
#   4. Compartir el calendario de Leandro con el service account
#
# GOOGLE_CALENDAR_CREDENTIALS_PATH=/home/leanvf/.hermes/profiles/nel-ai-vendedor/secrets/google-calendar-sa.json
# GOOGLE_CALENDAR_ID=primary    # O el ID específico del calendario de Leandro


# ============================================================================
# TRELLO (gestión de leads — kanban)
# ============================================================================
# Documentación: https://developer.atlassian.com/cloud/trello
# Requisitos:
#   1. Crear Power-Up en https://trello.com/power-ups/admin
#   2. Obtener API key y token
#   3. Crear board "ALMANAC Leads" si no existe
#
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_ID=


# ============================================================================
# CHATWOOT (conexión como agente conversacional)
# ============================================================================
# Documentación: https://www.chatwoot.com/developers/api/
# Estado: CONFIGURADO 2026-07-11
# Origen de las credenciales: ~/.hermes/secrets/services.env
# ⚠️  ROTAR DESPUÉS: el token está en services.env Y ahora en este .env
# ============================================================================

CHATWOOT_BASE_URL=
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=

# Intervalo de polling del daemon (segundos)
# Bajado de 8 a 3 el 2026-07-11 para reducir latencia ~5s sin apenas más carga
# NO bajar de 2s para no saturar la API de Chatwoot
NEL_DAEMON_INTERVAL=

# Identidad del agente Nel AI dentro de Chatwoot
CHATWOOT_AGENT_NAME=
CHATWOOT_AGENT_EMAIL=

# Filtros: solo responder conversaciones de estos inboxes (whatsapp canal principal)
# Si querés que Nel AI atienda TODOS los inboxes, dejá CHATWOOT_INBOX_IDS vacío
# Configurado 2026-07-11: inbox WhatsApp Business ALMANAC (id=2)
CHATWOOT_INBOX_IDS=

# Modo de operación:
# - "auto": responde automáticamente todas las conversaciones nuevas
# - "assisted": solo sugiere respuestas, el humano las envía
# - "on_handoff": solo toma conversaciones cuando un humano las deriva
# Cambiado a "auto" 2026-07-11 para pruebas iniciales con vos mandando mensajes reales
CHATWOOT_MODE=

# Loop prevention: Nel AI no responde a mensajes que vengan de agentes (otros humanos o bots)
CHATWOOT_IGNORE_AGENT_MESSAGES=


# ============================================================================
# FLOW.CL (webhooks de pago) — NO TOCAR, solo para Leandro
# ============================================================================
# Documentación: https://www.flow.cl/docs/api.html
# Esta integración es SOLO para el perfil `default` (Leandro).
# Nel AI NO debe tener acceso a estas credenciales (regla de seguridad).
#
# FLOW_API_KEY=                 # NO CONFIGURAR EN ESTE PERFIL
# FLOW_SECRET_KEY=              # NO CONFIGURAR EN ESTE PERFIL


# ============================================================================
# GOOGLE WORKSPACE (Gmail/Drive/Sheets) — solo si se activa Nel AI Standard
# ============================================================================
# NO requerido para el bot vendedor básico. Solo si más adelante se le da
# acceso a Gmail/Drive/Sheets para consultar info del cliente.
#
# GOOGLE_WORKSPACE_CREDENTIALS_PATH=/home/leanvf/.hermes/profiles/nel-ai-vendedor/secrets/google-workspace.json


# ============================================================================
# ZOHO MAIL (envío de correos) — NO TOCAR, solo para Leandro
# ============================================================================
# NO configurar acá. El envío de correos lo hace Leandro desde el perfil default.
#
# ZOHO_SMTP_USER=               # NO CONFIGURAR
# ZOHO_SMTP_PASS=               # NO CONFIGURAR

MCP_HIGGSFIELD_BEARER=
