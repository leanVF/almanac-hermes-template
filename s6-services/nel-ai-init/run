#!/bin/sh
# Servicio s6 para preparar el perfil y los symlinks.
# Genera el .env del perfil desde las env vars de Coolify.

set -e

echo "[nel-ai-init] Inicializando perfil de Nel AI Vendedor..."

export HERMES_HOME=/opt/data
ENV_FILE="$HERMES_HOME/profiles/nel-ai-vendedor/.env"

# 1. Crear el perfil si no existe
if [ ! -d "$HERMES_HOME/profiles/nel-ai-vendedor" ]; then
    echo "[nel-ai-init] Perfil no existe, copiando desde /opt/nel-ai/profile/"
    mkdir -p "$HERMES_HOME/profiles"
    cp -r /opt/nel-ai/profile "$HERMES_HOME/profiles/nel-ai-vendedor"
fi

# 2. Crear el .env desde las env vars del container (Coolify)
# SIEMPRE se regenera (no preserva el viejo) para asegurar valores frescos
echo "[nel-ai-init] Generando .env desde env vars de Coolify..."
echo "[nel-ai-init] Debug env vars:"
for var in CHATWOOT_BASE_URL CHATWOOT_API_TOKEN CHATWOOT_ACCOUNT_ID CHATWOOT_INBOX_IDS HERMES_GATEWAY_URL NEL_DAEMON_INTERVAL; do
    val=$(eval echo \$$var)
    if [ -z "$val" ]; then
        echo "[nel-ai-init]   $var = (VACÍA)"
    else
        # Mostrar primeros 10 y últimos 4 chars
        if [ ${#val} -gt 20 ]; then
            shown="${val:0:10}...${val: -4}"
        else
            shown="$val"
        fi
        echo "[nel-ai-init]   $var = $shown"
    fi
done
cat > "$ENV_FILE" <<EOF
# Generado automáticamente por nel-ai-init desde Coolify env vars
# NO editar a mano — los cambios se pierden en el próximo deploy

CHATWOOT_BASE_URL=${CHATWOOT_BASE_URL:-}
CHATWOOT_API_TOKEN=${CHATWOOT_API_TOKEN:-}
CHATWOOT_ACCOUNT_ID=${CHATWOOT_ACCOUNT_ID:-1}
CHATWOOT_AGENT_NAME=${CHATWOOT_AGENT_NAME:-Nel AI Vendedor}
CHATWOOT_AGENT_EMAIL=${CHATWOOT_AGENT_EMAIL:-nel-ai-vendedor@almanac.lat}
CHATWOOT_INBOX_IDS=${CHATWOOT_INBOX_IDS:-2,4}
CHATWOOT_MODE=${CHATWOOT_MODE:-auto}
CHATWOOT_IGNORE_AGENT_MESSAGES=${CHATWOOT_IGNORE_AGENT_MESSAGES:-true}
HERMES_GATEWAY_URL=${HERMES_GATEWAY_URL:-http://127.0.0.1:8642}
NEL_DAEMON_INTERVAL=${NEL_DAEMON_INTERVAL:-8}
NEL_WEBHOOK_HOST=${NEL_WEBHOOK_HOST:-127.0.0.1}
NEL_WEBHOOK_PORT=${NEL_WEBHOOK_PORT:-8766}
TELEGRAM_BOT_TOKEN=${TELEGRAM_BOT_TOKEN:-}
TELEGRAM_CHAT_ID=${TELEGRAM_CHAT_ID:-}
TRELLO_API_KEY=${TRELLO_API_KEY:-}
TRELLO_TOKEN=${TRELLO_TOKEN:-}
TRELLO_BOARD_ID=${TRELLO_BOARD_ID:-}
MCP_HIGGSFIELD_BEARER=${MCP_HIGGSFIELD_BEARER:-}
EOF
chmod 600 "$ENV_FILE"
echo "[nel-ai-init] .env creado en $ENV_FILE"

# 3. Crear symlinks para los assets
mkdir -p "$HERMES_HOME/work/almanac-onboarding/configuracion"
for f in frases-y-tono productos precios informacion-general que-hacemos mercado-competencia mision-vision; do
    if [ -f "/opt/nel-ai/configuracion/${f}.md" ] && [ ! -e "$HERMES_HOME/work/almanac-onboarding/configuracion/${f}.md" ]; then
        ln -s "/opt/nel-ai/configuracion/${f}.md" "$HERMES_HOME/work/almanac-onboarding/configuracion/${f}.md"
        echo "[nel-ai-init]   link: ${f}.md"
    fi
done

# 4. Crear directorio de logs
mkdir -p "$HERMES_HOME/profiles/nel-ai-vendedor/logs"

echo "[nel-ai-init] Inicialización completa."

exit 0
